POSTGRES_DB=kefumonitor
POSTGRES_USER=kefu
POSTGRES_PASSWORD=kefu_pass
DATABASE_URL=postgresql://kefu:kefu_pass@postgres:5432/kefumonitor?schema=public
REDIS_URL=redis://redis:6379
PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://localhost:5174

UDESC_BASE_URL=https://your-subdomain.udesk.cn
UDESC_EMAIL=your_email@example.com
UDESC_PASSWORD=replace_me
UDESC_TOKEN=
UDESC_SIGN_VERSION=v2
UDESC_SSO_SECRET=
UDESC_SYNC_PAGE_SIZE=100
UDESC_IM_SESSION_PATH=im/sessions/search
UDESC_IM_VOTE_PATH=im/sessions/vote
UDESC_IM_LOG_PATH=im/sessions/log
UDESC_SYNC_FETCH_LOGS=true
UDESC_LOG_SYNC_PAGE_SIZE=100
UDESC_LOG_MAX_PAGES_PER_SESSION=10
UDESC_SYNC_START_DATE=2026-01-01T00:00:00.000Z
UDESC_SYNC_WINDOW_DAYS=1
UDESC_PROVIDER_MAX_LOOKBACK_DAYS=30

ZOUWU_BASE_URL=https://api.zouwu.example.com
ZOUWU_API_KEY=replace_me
ZOUWU_SYNC_PAGE_SIZE=100

SYNC_CRON=0 */6 * * *
SYNC_LOOKBACK_DAYS=30
SYNC_RETRY_MAX_ATTEMPTS=3
SYNC_RETRY_BASE_DELAY_MS=1000
SYNC_ENABLE_ZOUWU=false
