# ===========================================
# 开发环境 - 本机运行 Docker 服务
# ===========================================
# 使用 Docker 容器中的 PostgreSQL 和 Redis
# 启动命令: docker compose up -d

# 数据库配置 - Docker 容器服务名
DATABASE_URL=postgresql://kefu:kefu_pass@postgres:5432/kefumonitor?schema=public&timezone=Asia/Shanghai
REDIS_URL=redis://redis:6379

# 服务配置
POSTGRES_DB=kefumonitor
POSTGRES_USER=kefu
POSTGRES_PASSWORD=kefu_pass
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080,http://localhost:5801

# Udesk 配置
UDESK_BASE_URL=https://gitcode.s2.udesk.cn
UDESK_EMAIL=chenjc@csdn.net
UDESK_PASSWORD=gitcode001
UDESK_TOKEN=
UDESK_SIGN_VERSION=v2
UDESK_SSO_SECRET=
UDESK_SYNC_PAGE_SIZE=100
UDESK_IM_SESSION_PATH=im/sessions/search
UDESK_IM_VOTE_PATH=im/sessions/vote
UDESK_IM_LOG_PATH=im/sessions/log
UDESK_SYNC_FETCH_LOGS=true
UDESK_LOG_SYNC_PAGE_SIZE=100
UDESK_LOG_MAX_PAGES_PER_SESSION=10
UDESK_SYNC_START_DATE=2026-01-01T00:00:00.000Z
UDESK_SYNC_WINDOW_DAYS=1
UDESK_PROVIDER_MAX_LOOKBACK_DAYS=30

# Zouwu 配置
ZOUWU_BASE_URL=https://zouwu.gitcode.com
ZOUWU_COOKIE_NAME=admin-plus-app-token
ZOUWU_APP_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMDkiLCJpYXQiOjE3NzU2MTczMDksImV4cCI6MTc3ODIwOTMwOX0._Y3IjQS-iE-AWiSTDgufvRuXqmrb-T5xaP5gBlvowe4
ZOUWU_PROXY_MODE=auto
ZOUWU_SYNC_PAGE_SIZE=100

# 同步配置
SYNC_HEARTBEAT_CRON=*/5 * * * *
SYNC_LOOKBACK_DAYS=30
SYNC_RETRY_MAX_ATTEMPTS=3
SYNC_RETRY_BASE_DELAY_MS=1000
SYNC_ENABLE_ZOUWU=true

# 企业微信登录（主主体）
WECOM_CORP_CORPID=
WECOM_CORP_SECRET=
VITE_WECOM_APPID=
VITE_WECOM_AGENTID=

# 企业微信登录（副主体）
WECOM_CSDN_CORPID=
WECOM_CSDN_SECRET=
VITE_WECOM_CSDN_APPID=
VITE_WECOM_CSDN_AGENTID=

# 前端配置
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_DISABLE_AUTH=true

# 登录 token 签名盐
AUTH_TOKEN_SECRET=dev_docker_secret
