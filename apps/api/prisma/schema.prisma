generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequirementStatus {
  OPEN
  IN_PROGRESS
  DONE
  CLOSED
  REJECTED
}

enum OpportunitySourceType {
  CONSULTATION
  MANUAL
}

enum OpportunityStatus {
  NEW
  QUALIFIED
  FOLLOWING
  WON
  LOST
}

model UdescSession {
  id                  String   @id
  agentId             String?
  startedAt           DateTime
  endedAt             DateTime?
  rating              Int?
  isConsultToDemand   Boolean  @default(false)
  rawPayload          Json?
  updatedAtSource     DateTime?
  syncedAt            DateTime @default(now())
  messages            UdescSessionMessage[]
  opportunities       BusinessOpportunity[]
  votes               UdescSessionVote[]
  metrics             UdescSessionMetrics?

  @@index([startedAt])
  @@index([updatedAtSource])
  @@index([isConsultToDemand])
}

model BusinessOpportunity {
  id               String                @id @default(cuid())
  title            String
  description      String?
  sourceType       OpportunitySourceType @default(MANUAL)
  sourceSessionId  String?
  agentId          String?
  customerName     String?
  contactInfo      String?
  estimatedAmount  Float?
  status           OpportunityStatus     @default(NEW)
  closeReason      String?
  closedAt         DateTime?
  nextAction       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  sourceSession    UdescSession?         @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([sourceType, createdAt])
  @@index([agentId, createdAt])
  @@index([sourceSessionId])
}

model UdescSessionMessage {
  id              String   @id
  sessionId       String
  sentAt          DateTime
  senderType      String?
  senderId        String?
  content         String?
  rawPayload      Json?
  syncedAt        DateTime @default(now())
  session         UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sentAt])
  @@index([senderType])
}

model ZouwuRequirement {
  id                  String            @id
  title               String
  sourceSessionId     String?
  status              RequirementStatus
  issueType           Int?              // 0=需求, 1=Bug
  isLongTerm          Boolean           @default(false)  // 是否长期演进
  createdById         String?           // 创建人ID
  createdByName       String?           // 创建人姓名
  createdAtSource     DateTime
  completedAtSource   DateTime?
  updatedAtSource     DateTime?
  rawPayload          Json?
  syncedAt            DateTime          @default(now())

  @@index([createdAtSource])
  @@index([completedAtSource])
  @@index([status])
  @@index([sourceSessionId])
  @@index([issueType])
  @@index([createdById])
  @@index([isLongTerm])
}

model SyncCheckpoint {
  source              String  @id
  cursor              String?
  lastSyncedAt        DateTime?
  updatedAt           DateTime @updatedAt
}

model SyncRun {
  id                  String   @id @default(cuid())
  source              String
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  status              String
  message             String?
  recordsSynced       Int      @default(0)

  @@index([source, startedAt])
}

model SyncIssue {
  id                  String   @id @default(cuid())
  runId               String
  source              String
  category            String
  externalId          String?
  payload             Json?
  errorMessage        String
  createdAt           DateTime @default(now())

  @@index([runId, source])
  @@index([source, createdAt])
}

model SyncConfig {
  source        String   @id
  enabled       Boolean  @default(true)
  intervalHours Int      @default(1)
  updatedAt     DateTime @updatedAt
}

// udesc 客服人员
model AgentProfile {
  agentId      String   @id
  displayName  String
  team         String?
  role         String?
  enabled      Boolean  @default(true)
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 企微员工 - 公司全部员工
model WecomEmployee {
  userId          String   @id  // 企微 userId
  name            String?
  department      String?
  position        String?
  mobile          String?
  email           String?
  avatar          String?
  enabled         Boolean  @default(true)
  isCustomerService Boolean @default(false)  // 是否客服部门
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
  @@index([isCustomerService])
}

// 系统日志
model SystemLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  level       String   // debug, info, warn, error
  module      String?  // sync, api, auth, etc.
  source      String?  // udesc, zouwu, etc.
  action      String?  // create, update, delete, etc.
  message     String
  context     Json?    // 额外上下文数据
  userId      String?  // 操作用户
  correlationId String? // 关联ID
  duration    Int?     // 耗时(ms)

  @@index([timestamp])
  @@index([level])
  @@index([module])
  @@index([source])
  @@index([userId])
}

// 会话评价详情
model UdescSessionVote {
  id          String   @id @default(cuid())
  sessionId   String
  rating      Int?
  tags        String[] // 评价标签
  comment     String?  // 评价内容
  voterId     String?  // 评价人ID
  voterName   String?  // 评价人名称
  votedAt     DateTime?
  rawPayload  Json?
  syncedAt    DateTime @default(now())
  session     UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([votedAt])
}

// 客户信息
model UdescCustomer {
  id            String   @id
  name          String?
  phone         String?
  email         String?
  wechat        String?
  enterprise    String?  // 所属企业
  tags          String[]
  customFields  Json?
  rawPayload    Json?
  updatedAtSource DateTime?
  syncedAt      DateTime @default(now())

  @@index([phone])
  @@index([email])
  @@index([enterprise])
}

// Udesk 客服详细信息
model UdescAgent {
  id          String   @id
  name        String?
  email       String?
  phone       String?
  roleId      String?
  roleName    String?
  enabled     Boolean  @default(true)
  groups      String[]
  skills      String[]
  rawPayload  Json?
  syncedAt    DateTime @default(now())

  @@index([enabled])
}

// 会话统计指标
model UdescSessionMetrics {
  id                    String   @id @default(cuid())
  sessionId             String   @unique
  firstResponseTime     Int?     // 首次响应时间(秒)
  avgResponseTime       Float?   // 平均响应时间(秒)
  waitTime              Int?     // 排队等待时间(秒)
  resolutionTime        Int?     // 解决时间(秒)
  messageCount          Int      @default(0)
  agentMessageCount     Int      @default(0)
  customerMessageCount  Int      @default(0)
  syncedAt              DateTime @default(now())
  session               UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
