generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequirementStatus {
  OPEN
  IN_PROGRESS
  DONE
  CLOSED
  REJECTED
}

enum OpportunitySourceType {
  CONSULTATION
  MANUAL
}

enum OpportunityStatus {
  NEW
  QUALIFIED
  FOLLOWING
  WON
  LOST
}

model UdescSession {
  id                  String   @id
  agentId             String?
  startedAt           DateTime
  endedAt             DateTime?
  rating              Int?
  isConsultToDemand   Boolean  @default(false)
  rawPayload          Json?
  updatedAtSource     DateTime?
  syncedAt            DateTime @default(now())
  messages            UdescSessionMessage[]
  opportunities       BusinessOpportunity[]

  @@index([startedAt])
  @@index([updatedAtSource])
  @@index([isConsultToDemand])
}

model BusinessOpportunity {
  id               String                @id @default(cuid())
  title            String
  description      String?
  sourceType       OpportunitySourceType @default(MANUAL)
  sourceSessionId  String?
  agentId          String?
  customerName     String?
  contactInfo      String?
  estimatedAmount  Float?
  status           OpportunityStatus     @default(NEW)
  closeReason      String?
  closedAt         DateTime?
  nextAction       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  sourceSession    UdescSession?         @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([sourceType, createdAt])
  @@index([agentId, createdAt])
  @@index([sourceSessionId])
}

model UdescSessionMessage {
  id              String   @id
  sessionId       String
  sentAt          DateTime
  senderType      String?
  senderId        String?
  content         String?
  rawPayload      Json?
  syncedAt        DateTime @default(now())
  session         UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sentAt])
  @@index([senderType])
}

model ZouwuRequirement {
  id                  String            @id
  title               String
  sourceSessionId     String?
  status              RequirementStatus
  createdAtSource     DateTime
  completedAtSource   DateTime?
  updatedAtSource     DateTime?
  rawPayload          Json?
  syncedAt            DateTime          @default(now())

  @@index([createdAtSource])
  @@index([completedAtSource])
  @@index([status])
  @@index([sourceSessionId])
}

model SyncCheckpoint {
  source              String  @id
  cursor              String?
  lastSyncedAt        DateTime?
  updatedAt           DateTime @updatedAt
}

model SyncRun {
  id                  String   @id @default(cuid())
  source              String
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  status              String
  message             String?
  recordsSynced       Int      @default(0)

  @@index([source, startedAt])
}

model SyncIssue {
  id                  String   @id @default(cuid())
  runId               String
  source              String
  category            String
  externalId          String?
  payload             Json?
  errorMessage        String
  createdAt           DateTime @default(now())

  @@index([runId, source])
  @@index([source, createdAt])
}

model SyncConfig {
  source        String   @id
  enabled       Boolean  @default(true)
  intervalHours Int      @default(1)
  updatedAt     DateTime @updatedAt
}

model AgentProfile {
  agentId      String   @id
  displayName  String
  team         String?
  role         String?
  enabled      Boolean  @default(true)
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
