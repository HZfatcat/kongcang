generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequirementStatus {
  OPEN
  IN_PROGRESS
  DONE
  CLOSED
  REJECTED
}

enum OpportunitySourceType {
  CONSULTATION
  MANUAL
}

enum OpportunityStatus {
  NEW
  QUALIFIED
  FOLLOWING
  WON
  LOST
}

model UdescSession {
  id                  String   @id
  agentId             String?
  startedAt           DateTime
  endedAt             DateTime?
  rating              Int?
  isConsultToDemand   Boolean  @default(false)
  rawPayload          Json?
  updatedAtSource     DateTime?
  syncedAt            DateTime @default(now())
  messages            UdescSessionMessage[]
  opportunities       BusinessOpportunity[]
  votes               UdescSessionVote[]
  metrics             UdescSessionMetrics?

  @@index([startedAt])
  @@index([updatedAtSource])
  @@index([isConsultToDemand])
}

model BusinessOpportunity {
  id               String                @id @default(cuid())
  title            String
  description      String?
  sourceType       OpportunitySourceType @default(MANUAL)
  sourceSessionId  String?
  agentId          String?
  customerName     String?
  contactInfo      String?
  estimatedAmount  Float?
  status           OpportunityStatus     @default(NEW)
  closeReason      String?
  closedAt         DateTime?
  nextAction       String?
  username         String?
  name             String?
  phone            String?
  email            String?
  companyName      String?
  requestType      String?
  requestDetails   String?
  feedbackChannel  String?
  feedbackPerson   String?
  feedbackResult   String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  sourceSession    UdescSession?         @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([sourceType, createdAt])
  @@index([agentId, createdAt])
  @@index([sourceSessionId])
}

model UdescSessionMessage {
  id              String   @id
  sessionId       String
  sentAt          DateTime
  senderType      String?
  senderId        String?
  content         String?
  rawPayload      Json?
  syncedAt        DateTime @default(now())
  session         UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sentAt])
  @@index([senderType])
}

model ZouwuRequirement {
  id                  String            @id
  title               String
  sourceSessionId     String?
  status              RequirementStatus
  issueType           Int?              // 0=需求, 1=Bug
  isLongTerm          Boolean           @default(false)  // 是否长期演进
  createdById         String?           // 创建人ID
  createdByName       String?           // 创建人姓名
  createdAtSource     DateTime
  completedAtSource   DateTime?
  updatedAtSource     DateTime?
  rawPayload          Json?
  syncedAt            DateTime          @default(now())

  @@index([createdAtSource])
  @@index([completedAtSource])
  @@index([status])
  @@index([sourceSessionId])
  @@index([issueType])
  @@index([createdById])
  @@index([isLongTerm])
}

model SyncCheckpoint {
  source              String  @id
  cursor              String?
  lastSyncedAt        DateTime?
  updatedAt           DateTime @updatedAt
}

model SyncRun {
  id                  String   @id @default(cuid())
  source              String
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  status              String
  message             String?
  recordsSynced       Int      @default(0)

  @@index([source, startedAt])
}

model SyncIssue {
  id                  String   @id @default(cuid())
  runId               String
  source              String
  category            String
  externalId          String?
  payload             Json?
  errorMessage        String
  createdAt           DateTime @default(now())
  resolvedAt          DateTime?

  @@index([runId, source])
  @@index([source, createdAt])
  @@index([source, category, externalId])
}

model SyncConfig {
  source        String   @id
  enabled       Boolean  @default(true)
  intervalHours Int      @default(1)
  updatedAt     DateTime @updatedAt
}

// ========== 权限管理模块 ==========

// 系统角色表
model SysRole {
  roleId      BigInt   @id @default(autoincrement())
  roleName    String   @map("role_name")
  roleDesc    String?  @map("role_desc")
  status      Int      @default(1)  // 0=禁用 1=启用
  createTime  DateTime @default(now()) @map("create_time")

  userRoles   SysUserRole[]
  roleMenus   SysRoleMenu[]

  @@map("sys_role")
}

// 用户角色关联表
model SysUserRole {
  id     BigInt  @id @default(autoincrement())
  userId String  @map("user_id")
  roleId BigInt  @map("role_id")

  role   SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade)

  @@map("sys_user_role")
  @@unique([userId, roleId])
}

// 角色菜单权限表
model SysRoleMenu {
  id          BigInt  @id @default(autoincrement())
  roleId      BigInt  @map("role_id")
  menuId      BigInt  @map("menu_id")
  buttonAuth  String? @map("button_auth")  // 按钮权限标识，多个用逗号分隔

  role        SysRole @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  menu        SysMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("sys_role_menu")
  @@unique([roleId, menuId])
}

// 系统菜单表
model SysMenu {
  id          BigInt   @id @default(autoincrement())
  parentId    BigInt   @default(0) @map("parent_id")
  menuName    String   @map("menu_name")
  menuType    Int      @default(1) @map("menu_type")  // 1=目录 2=菜单 3=按钮
  path        String?
  component   String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  status      Int      @default(1)
  createTime  DateTime @default(now()) @map("create_time")

  roleMenus   SysRoleMenu[]

  @@map("sys_menu")
}

// 用户数据权限表
model SysUserDataScope {
  id        BigInt  @id @default(autoincrement())
  userId    String  @map("user_id")
  dataScope Int     @default(1) @map("data_scope")  // 1=个人 2=部门 3=全部

  @@map("sys_user_data_scope")
  @@unique([userId])
}

// 权限操作日志表
model SysPermissionLog {
  logId       BigInt   @id @default(autoincrement())
  operator    String   @map("operator")
  operateTime DateTime @default(now()) @map("operate_time")
  operateIp   String?  @map("operate_ip")
  targetUser  String?  @map("target_user")
  beforeAuth  String?  @map("before_auth")
  afterAuth   String?  @map("after_auth")
  operateType String   @map("operate_type")

  @@map("sys_permission_log")
  @@index([operateTime])
  @@index([operator])
  @@index([targetUser])
}

// udesc 客服人员
model AgentProfile {
  agentId      String   @id
  displayName  String
  team         String?
  role         String?
  enabled      Boolean  @default(true)
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 企微员工 - 公司全部员工
model WecomEmployee {
  userId          String   @id  // 企微 userId
  name            String?
  department      String?
  position        String?
  mobile          String?
  email           String?
  avatar          String?
  enabled         Boolean  @default(true)
  isCustomerService Boolean @default(false)  // 是否客服部门
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
  @@index([isCustomerService])
}

// 系统日志
model SystemLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  level       String   // debug, info, warn, error
  module      String?  // sync, api, auth, etc.
  source      String?  // udesc, zouwu, etc.
  action      String?  // create, update, delete, etc.
  message     String
  context     Json?    // 额外上下文数据
  userId      String?  // 操作用户
  correlationId String? // 关联ID
  duration    Int?     // 耗时(ms)

  @@index([timestamp])
  @@index([level])
  @@index([module])
  @@index([source])
  @@index([userId])
}

// 会话评价详情
model UdescSessionVote {
  id          String   @id @default(cuid())
  sessionId   String
  rating      Int?
  tags        String[] // 评价标签
  comment     String?  // 评价内容
  voterId     String?  // 评价人ID
  voterName   String?  // 评价人名称
  votedAt     DateTime?
  rawPayload  Json?
  syncedAt    DateTime @default(now())
  session     UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([votedAt])
}

// 客户信息
model UdescCustomer {
  id            String   @id
  name          String?
  phone         String?
  email         String?
  wechat        String?
  enterprise    String?  // 所属企业
  tags          String[]
  customFields  Json?
  rawPayload    Json?
  updatedAtSource DateTime?
  syncedAt      DateTime @default(now())

  @@index([phone])
  @@index([email])
  @@index([enterprise])
}

// Udesk 客服详细信息
model UdescAgent {
  id          String   @id
  name        String?
  email       String?
  phone       String?
  roleId      String?
  roleName    String?
  enabled     Boolean  @default(true)
  groups      String[]
  skills      String[]
  rawPayload  Json?
  syncedAt    DateTime @default(now())

  @@index([enabled])
}

// 会话统计指标
model UdescSessionMetrics {
  id                    String   @id @default(cuid())
  sessionId             String   @unique
  firstResponseTime     Int?     // 首次响应时间(秒)
  avgResponseTime       Float?   // 平均响应时间(秒)
  waitTime              Int?     // 排队等待时间(秒)
  resolutionTime        Int?     // 解决时间(秒)
  messageCount          Int      @default(0)
  agentMessageCount     Int      @default(0)
  customerMessageCount  Int      @default(0)
  syncedAt              DateTime @default(now())
  session               UdescSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([firstResponseTime])
  @@index([avgResponseTime])
  @@index([waitTime])
  @@index([resolutionTime])
}
